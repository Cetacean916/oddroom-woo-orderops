#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
package_root=$(CDPATH= cd -- "$script_dir/../../.." && pwd)
resume_path="$package_root/.pf07/prerequisite-resume.json"

show_dialog() {
  /usr/bin/osascript -e "display dialog \"$1\" with title \"OddRoom OrderOps\" buttons {\"OK\"} default button \"OK\" with icon caution" >/dev/null
}

offer_url() {
  answer=$(/usr/bin/osascript -e "display dialog \"$1\" with title \"OddRoom OrderOps\" buttons {\"Later\", \"Open official page\"} default button \"Open official page\" with icon caution" -e 'button returned of result')
  if [ "$answer" = "Open official page" ]; then
    /usr/bin/open "$2"
  fi
}

if [ ! -f "$package_root/packaging/common/action-contract.json" ]; then
  show_dialog "The PF07 package is incomplete. Extract the complete ZIP into one folder and try again."
  exit 13
fi

if ! command -v python3 >/dev/null 2>&1; then
  mkdir -p "$package_root/.pf07"
  printf '%s\n' '{"schema":"pf07.prerequisite-resume.v1","state":"MISSING_PYTHON","next_action":"Hub"}' > "$resume_path"
  offer_url "Python 3.10 or newer is required. Install it from the official page, then open PF07 Launcher.app again to resume." "https://www.python.org/downloads/macos/"
  exit 20
fi

export PYTHONPATH="$package_root/launcher${PYTHONPATH:+:$PYTHONPATH}"
preflight=$(python3 -m pf07_launcher.cli preflight 2>&1) || {
  show_dialog "$preflight"
  exit 21
}
state=$(printf '%s' "$preflight" | python3 -c 'import json,sys; print(json.load(sys.stdin)["state"])')
if [ "$state" != "READY" ]; then
  mkdir -p "$package_root/.pf07"
  printf '{"schema":"pf07.prerequisite-resume.v1","state":"%s","next_action":"Hub"}\n' "$state" > "$resume_path"
  offer_url "A ready Docker-compatible runtime with Compose is required. Install Rancher Desktop, select its Moby engine, wait for Ready, then open this app again. This is the maintained 0-KRW path for this package." "https://rancherdesktop.io/"
  exit 22
fi
rm -f "$resume_path"
exec python3 -m pf07_launcher.hub
