server {
    listen 443 ssl http2;
    server_name pf07.example.invalid;

    # Configure reviewed certificate paths before enabling this example.
    ssl_certificate /etc/ssl/pf07/fullchain.pem;
    ssl_certificate_key /etc/ssl/pf07/privkey.pem;

    location / {
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass http://127.0.0.1:19081;
    }

    # n8n, MariaDB, Docker APIs, evidence, logs, and metrics have no public route.
}
