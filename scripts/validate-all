#!/usr/bin/env python3
from __future__ import annotations

from datetime import datetime
import hashlib
import json
from pathlib import Path
import re
import stat
import subprocess
import sys

from refinement_evidence_paths import (
    LEGACY_PUBLIC_MANIFEST_SHA256,
    LEGACY_RAW_MANIFEST_SHA256,
    PUBLIC_RUN_ALIAS,
    SUCCESSOR_PUBLIC_PREFIX,
    successor_public_root,
    successor_raw_root,
)

from evidence_contract import EvidenceContractError, validate_public_lineage


ROOT = Path(__file__).resolve().parent.parent
RAW_ROOT = successor_raw_root(ROOT)
PUBLIC_ROOT = successor_public_root(ROOT)
COMMON_FIELDS = {
    "schema_version", "acceptance_id", "run_id", "started_at", "finished_at",
    "source_tree_sha256", "command_or_probe", "exit_code", "observations",
    "artifact_hashes", "redaction_state",
}
PRE_PUBLIC_RAW = [
    "e2e-normal-order.json", "e2e-variable-coupon-order.json",
    "duplicate-suppression.json", "state-non-regression.json",
    "hmac-rejection.json", "raw-byte-resource-bounds.json",
    "outage-retry.json", "retry-exhaustion.json", "stale-lease-recovery.json",
    "partial-failure-recovery.json", "operator-outcome-resolution.json",
    "reconciliation-repair.json", "hpos-compatibility.json",
    "product-quality.json", "restore-drill.json",
]
PRIMARY_GATES = {
    "GATE-01": "e2e-normal-order.json",
    "GATE-02": "state-non-regression.json",
    "GATE-03": "e2e-variable-coupon-order.json",
    "GATE-04": "duplicate-suppression.json",
    "GATE-05": "hmac-rejection.json",
    "GATE-06": "outage-retry.json",
    "GATE-07": "partial-failure-recovery.json",
    "GATE-08": "reconciliation-repair.json",
    "GATE-09": "product-quality.json",
    "GATE-10": "restore-drill.json",
}


def fail(message: str) -> None:
    raise SystemExit(f"FAIL: {message}")


def sha256_bytes(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def sha256_file(path: Path) -> str:
    return sha256_bytes(path.read_bytes())


def load_json(path: Path) -> dict:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        fail(f"cannot read {path}: {error}")
    if not isinstance(value, dict):
        fail(f"JSON root is not an object: {path}")
    return value


def parse_time(value: object, label: str) -> None:
    if not isinstance(value, str):
        fail(f"{label} is not a timestamp string")
    try:
        datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        fail(f"{label} is not RFC3339-compatible")


def source_tree_sha256() -> str:
    lines: list[str] = []
    for path in sorted(ROOT.rglob("*")):
        relative = path.relative_to(ROOT)
        if not path.is_file() or path.is_symlink():
            continue
        if relative.parts[0] in {"dist", "evidence", "reports", "runtime", ".git"}:
            continue
        if "node_modules" in relative.parts or "__pycache__" in relative.parts or path.suffix == ".pyc":
            continue
        if relative.as_posix() == "release/public-build-manifest.json":
            continue
        mode = "0755" if path.stat().st_mode & stat.S_IXUSR else "0644"
        lines.append(f"{relative.as_posix()}\t{mode}\t{sha256_file(path)}")
    return sha256_bytes(("\n".join(lines) + "\n").encode("utf-8"))


def parse_manifest(path: Path) -> dict[str, str]:
    entries: dict[str, str] = {}
    for line in path.read_text(encoding="utf-8").splitlines():
        match = re.fullmatch(r"([0-9a-f]{64})  ([a-zA-Z0-9._/-]+)", line)
        if not match or match.group(2) in entries:
            fail(f"invalid or duplicate manifest line in {path.name}")
        entries[match.group(2)] = match.group(1)
    return entries


def run_public_safe_check(label: str, command: list[str]) -> None:
    result = subprocess.run(
        command,
        cwd=ROOT,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    if result.returncode != 0:
        fail(f"{label} failed without establishing the linked criterion: {result.stdout.strip()}")


if len(sys.argv) != 2 or sys.argv[1] not in {"--pre-public", "--final"}:
    fail("usage: scripts/validate-all <--pre-public|--final>")
mode = sys.argv[1]

if not RAW_ROOT.is_dir() or not PUBLIC_ROOT.is_dir():
    fail("successor raw-private and public evidence roots are required")

legacy_raw_manifest = ROOT / "evidence/raw/evidence-manifest.sha256"
legacy_public_manifest = ROOT / "evidence/public/evidence-manifest.sha256"
if not legacy_raw_manifest.is_file() or sha256_file(legacy_raw_manifest) != LEGACY_RAW_MANIFEST_SHA256:
    fail("historical v1.0.2 raw evidence manifest changed")
if not legacy_public_manifest.is_file() or sha256_file(legacy_public_manifest) != LEGACY_PUBLIC_MANIFEST_SHA256:
    fail("historical v1.0.2 public evidence manifest changed")

source_hash = source_tree_sha256()
inventory = load_json(RAW_ROOT / "protected-artifact-inventory.json")
artifacts = inventory.get("artifacts")
if inventory.get("schema_version") != 1 or not isinstance(artifacts, dict) or not artifacts:
    fail("protected artifact inventory is invalid")
for alias, item in artifacts.items():
    if not re.fullmatch(r"[a-z0-9_]+", alias) or not isinstance(item, dict):
        fail(f"protected artifact alias is invalid: {alias}")
    relative = item.get("path")
    digest = item.get("sha256")
    if not isinstance(relative, str) or not relative.startswith("artifacts/") or ".." in Path(relative).parts:
        fail(f"protected artifact path is invalid: {alias}")
    path = RAW_ROOT / relative
    if not path.is_file() or sha256_file(path) != digest:
        fail(f"protected artifact hash mismatch: {alias}")

raw_records: dict[str, dict] = {}
run_ids: set[str] = set()
for name in PRE_PUBLIC_RAW:
    path = RAW_ROOT / name
    record = load_json(path)
    missing = COMMON_FIELDS - record.keys()
    if missing or record.get("redaction_state") != "RAW_PROTECTED":
        fail(f"raw common schema failed: {name} {sorted(missing)}")
    if record.get("exit_code") != 0:
        fail(f"raw executable probe did not exit zero: {name}")
    observations = record.get("observations")
    if not isinstance(observations, dict) or observations.get("result") != "PASS":
        fail(f"raw observations do not establish PASS: {name}")
    if record.get("source_tree_sha256") != source_hash:
        fail(f"source-tree commitment mismatch: {name}")
    parse_time(record.get("started_at"), f"{name}.started_at")
    parse_time(record.get("finished_at"), f"{name}.finished_at")
    run_id = record.get("run_id")
    if not isinstance(run_id, str) or not run_id:
        fail(f"raw run ID is missing: {name}")
    run_ids.add(run_id)
    artifact_hashes = record.get("artifact_hashes")
    if not isinstance(artifact_hashes, dict) or not artifact_hashes:
        fail(f"raw artifact hashes are missing: {name}")
    for alias, digest in artifact_hashes.items():
        if not re.fullmatch(r"[a-z0-9_]+", str(alias)) or not re.fullmatch(r"[0-9a-f]{64}", str(digest)):
            fail(f"raw artifact alias or digest is invalid: {name}")
        if alias not in artifacts or artifacts[alias]["sha256"] != digest:
            fail(f"raw artifact is not inventory-bound: {name}:{alias}")
    raw_records[name] = record
if len(run_ids) != 1:
    fail("pre-public records do not share one protected acceptance run")

vsl = load_json(RAW_ROOT / "vsl-pass.json")
if (
    COMMON_FIELDS - vsl.keys()
    or vsl.get("acceptance_id") != "VSL-PASS"
    or vsl.get("run_id") not in run_ids
    or vsl.get("source_tree_sha256") != source_hash
    or vsl.get("exit_code") != 0
    or vsl.get("redaction_state") != "RAW_PROTECTED"
):
    fail("successor VSL record schema or source/run binding failed")
vsl_observations = vsl.get("observations")
if not isinstance(vsl_observations, dict) or vsl_observations.get("result") != "PASS":
    fail("successor VSL observations do not establish PASS")
if vsl_observations.get("baseline_ids") != [f"VSL-{index:03d}" for index in range(1, 6)]:
    fail("successor VSL baseline inventory differs")
for vsl_id in vsl_observations["baseline_ids"]:
    row = vsl_observations.get(vsl_id)
    if not isinstance(row, dict) or row.get("result") != "PASS":
        fail(f"successor VSL row did not pass: {vsl_id}")
vsl_artifacts = vsl.get("artifact_hashes")
if not isinstance(vsl_artifacts, dict) or not vsl_artifacts:
    fail("successor VSL artifact commitments are missing")
for alias, digest in vsl_artifacts.items():
    if alias not in artifacts or artifacts[alias].get("sha256") != digest:
        fail(f"successor VSL artifact is not inventory-bound: {alias}")

fixture_result = subprocess.run(
    [str(ROOT / "fixtures/run"), "--protected"],
    cwd=ROOT,
    text=True,
    stdout=subprocess.PIPE,
    stderr=subprocess.STDOUT,
    check=False,
)
if fixture_result.returncode != 0:
    fail(f"executable protected fixture bundle failed: {fixture_result.stdout.strip()}")
fixture_summary = json.loads(fixture_result.stdout)
if fixture_summary.get("status") != "PASS" or fixture_summary.get("fixture_count") != 15:
    fail("protected fixture bundle did not establish all fifteen scenarios")

raw_manifest = parse_manifest(RAW_ROOT / "evidence-manifest.sha256")
expected_raw_manifest = {
    path.relative_to(ROOT).as_posix(): sha256_file(path)
    for path in RAW_ROOT.rglob("*")
    if path.is_file() and path.name != "evidence-manifest.sha256"
}
if raw_manifest != expected_raw_manifest:
    fail("protected raw manifest inventory or hashes differ")

public_manifest = parse_manifest(PUBLIC_ROOT / "evidence-manifest.sha256")
expected_public_manifest = {
    path.relative_to(ROOT).as_posix(): sha256_file(path)
    for path in PUBLIC_ROOT.glob("*")
    if path.is_file() and path.name != "evidence-manifest.sha256"
}
if public_manifest != expected_public_manifest:
    fail("public manifest inventory or hashes differ")

public_hash_values = set(public_manifest.values()) | {sha256_file(PUBLIC_ROOT / "evidence-manifest.sha256")}
for name, raw in {**raw_records, "vsl-pass.json": vsl}.items():
    if set(raw["artifact_hashes"].values()) & public_hash_values:
        fail(f"backward edge from raw to derived public output: {name}")

transform_sha = sha256_file(ROOT / "scripts/generate-public-evidence")
public_records: dict[str, dict] = {}
for name in PRE_PUBLIC_RAW:
    public_path = PUBLIC_ROOT / name
    public = load_json(public_path)
    raw_path = RAW_ROOT / name
    try:
        validate_public_lineage(public, raw_records[name], raw_path.read_bytes(), transform_sha)
    except EvidenceContractError as error:
        fail(f"complete raw-to-public lineage failed: {name}: {error}")
    if public.get("source_tree_sha256") != source_hash:
        fail(f"public record does not bind the current source tree: {name}")
    public_records[name] = public

public_vsl = load_json(PUBLIC_ROOT / "vsl-pass.json")
try:
    validate_public_lineage(public_vsl, vsl, (RAW_ROOT / "vsl-pass.json").read_bytes(), transform_sha)
except EvidenceContractError as error:
    fail(f"complete raw-to-public VSL lineage failed: {error}")
if public_vsl.get("source_tree_sha256") != source_hash:
    fail("public VSL record does not bind the current source tree")

public_by_gate: dict[str, tuple[str, dict]] = {}
for gate, raw_name in PRIMARY_GATES.items():
    public_name = raw_name
    public = public_records[public_name]
    public_by_gate[gate] = (public_name, public)

matrix = load_json(PUBLIC_ROOT / "acceptance-matrix.json")
entries = matrix.get("entries")
if (
    matrix.get("schema_version") != "1"
    or matrix.get("acceptance_id") != "ACCEPTANCE-MATRIX"
    or matrix.get("run_id") != PUBLIC_RUN_ALIAS
    or matrix.get("source_tree_sha256") != source_hash
    or matrix.get("exit_code") != 0
    or matrix.get("artifact_hashes") != {}
    or matrix.get("redaction_state") != "PUBLIC_ORIGINAL_SAFE"
    or matrix.get("matrix_scope") != "PRE_PUBLIC_BUYER_PROOF"
    or matrix.get("observations") != {"result": "PASS", "gate_count": 10, "final_pass_claimed": False}
    or not isinstance(entries, list)
):
    fail("public buyer-proof matrix metadata failed")
if [entry.get("acceptance_id") for entry in entries] != sorted(PRIMARY_GATES):
    fail("public buyer-proof matrix must contain exactly GATE-01 through GATE-10")
for entry in entries:
    gate = entry["acceptance_id"]
    public_name, _ = public_by_gate[gate]
    if entry.get("result") != "PASS" or entry.get("record_path") != f"{SUCCESSOR_PUBLIC_PREFIX}/{public_name}" or entry.get("record_sha256") != sha256_file(PUBLIC_ROOT / public_name):
        fail(f"public buyer-proof matrix link failed: {gate}")

claims = (ROOT / "docs/CLAIMS-BOUNDARY.md").read_text(encoding="utf-8")
case = (ROOT / "case-study/README.md").read_text(encoding="utf-8")
for phrase in [
    "Production load, scale, uptime", "Real payment", "Formal exactly-once",
    "captured, still-valid signed request", "Slack accepted/response-lost window",
    "unrelated external writers", "source-available dependency",
]:
    if phrase.lower() not in (claims + case).lower():
        fail(f"required claim boundary is missing: {phrase}")

if mode == "--final":
    release = load_json(RAW_ROOT / "public-release.json")
    final_matrix = load_json(RAW_ROOT / "acceptance-matrix.json")
    for name, record in (("public-release.json", release), ("acceptance-matrix.json", final_matrix)):
        if COMMON_FIELDS - record.keys() or record.get("redaction_state") != "RAW_PROTECTED" or record.get("source_tree_sha256") != source_hash or record.get("exit_code") != 0:
            fail(f"final raw record schema/result failed: {name}")
        parse_time(record.get("started_at"), f"{name}.started_at")
        parse_time(record.get("finished_at"), f"{name}.finished_at")
        if record.get("run_id") not in run_ids:
            fail(f"final raw record does not share the protected acceptance run: {name}")
        record_artifacts = record.get("artifact_hashes")
        if not isinstance(record_artifacts, dict) or not record_artifacts:
            fail(f"final raw artifact commitments are missing: {name}")
        for alias, digest in record_artifacts.items():
            if alias not in artifacts or artifacts[alias].get("sha256") != digest:
                fail(f"final raw artifact is not inventory-bound: {name}:{alias}")
    release_observations = release.get("observations", {})
    if (
        release_observations.get("result") != "PASS"
        or release_observations.get("identity_chain_exact") is not True
        or release_observations.get("authenticated_clone_exact") is not True
        or release_observations.get("unauthenticated_https_clone_exact") is not True
        or release_observations.get("visibility_transition") != "PRIVATE_TO_PUBLIC"
        or release_observations.get("visibility_transition_commit_and_tree_unchanged") is not True
        or release_observations.get("final_private_ci_result") != "success"
        or release_observations.get("final_public_ci_result") != "success"
        or release_observations.get("repository_only_public_validation") != "PASS"
        or release_observations.get("post_public_validation") != "PASS"
        or release_observations.get("registration_case_count") != 6
    ):
        fail("public release identity chain did not pass")
    expected_ids = [f"GATE-{index:02d}" for index in range(1, 11)] + [f"REL-{index:03d}" for index in range(1, 9)] + [f"ACC-{index:03d}" for index in range(1, 19)]
    final_entries = final_matrix.get("entries")
    if not isinstance(final_entries, list) or [entry.get("acceptance_id") for entry in final_entries] != expected_ids or any(entry.get("result") != "PASS" for entry in final_entries):
        fail("final acceptance matrix is incomplete or non-PASS")
    if final_matrix.get("observations") != {
        "result": "PASS",
        "final_pass": True,
        "gate_count": 10,
        "release_gate_count": 8,
        "acceptance_criterion_count": 18,
        "entry_count": 36,
    }:
        fail("final matrix does not establish final pass")

run_public_safe_check("public builder regression", [sys.executable, "tests/test_public_builder.py"])
run_public_safe_check("evidence lineage regression", [sys.executable, "tests/test_evidence_contract.py"])
run_public_safe_check("generated workflow drift", [str(ROOT / "scripts/build-workflow"), "--check"])
run_public_safe_check("workflow and plugin static contract", [sys.executable, "tests/test_vsl_contract.py"])
run_public_safe_check("workflow resume semantics", ["node", "tests/workflow_resume_semantics.mjs"])
run_public_safe_check(
    "public-safe aggregate validation",
    [str(ROOT / "scripts/validate-public"), "--post-public" if mode == "--final" else "--pre-public"],
)

print(f"PASS: aggregate {mode[2:]} validation established {len(raw_records)} gate records and complete evidence lineage")
