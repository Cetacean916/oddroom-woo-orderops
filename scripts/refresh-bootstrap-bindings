#!/usr/bin/env python3
from __future__ import annotations

import hashlib
import json
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
OUTPUT = ROOT / "packaging/common/distribution-content-bindings.json"


def sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as source:
        for block in iter(lambda: source.read(1024 * 1024), b""):
            digest.update(block)
    return digest.hexdigest()


def add_tree(rows: list[dict[str, object]], source_root: str, target_root: str) -> None:
    directory = ROOT / source_root
    for path in sorted(directory.rglob("*")):
        if not path.is_file() or "__pycache__" in path.parts or path.suffix in {".pyc", ".pyo"}:
            continue
        suffix = path.relative_to(directory).as_posix()
        rows.append(
            {
                "source": path.relative_to(ROOT).as_posix(),
                "package_path": f"{target_root}/{suffix}",
                "sha256": sha256(path),
                "bytes": path.stat().st_size,
            }
        )


def main() -> None:
    rows: list[dict[str, object]] = []
    add_tree(rows, "plugin/oddroom-orderops", "payload/oddroom-orderops")
    add_tree(rows, "launcher/pf07_launcher", "launcher/pf07_launcher")
    add_tree(rows, "launcher/ui", "launcher/ui")
    for relative in (
        "launcher/bin/pf07",
        "launcher/bin/pf07-hub",
        "packaging/common/action-contract.json",
        "packaging/common/prerequisites.json",
        "packaging/common/compose.yaml",
        "packaging/common/n8n-task-runners.json",
        "packaging/common/task-runner.Dockerfile",
        "packaging/common/task-runner-deps/package.json",
        "packaging/common/task-runner-deps/package-lock.json",
        "packaging/common/seed/seed-manifest.json",
        "packaging/common/seed/catalogs/ko_KR.json",
        "packaging/common/seed/catalogs/en_US.json",
        "packaging/common/workflows/demo-mode.json",
        "packaging/common/workflows/connected-mode.json",
        "packaging/network/tunnel-route-allowlist.json",
    ):
        path = ROOT / relative
        rows.append({"source": relative, "package_path": relative, "sha256": sha256(path), "bytes": path.stat().st_size})
    rows.sort(key=lambda item: str(item["package_path"]))
    digest = hashlib.sha256()
    for item in rows:
        digest.update(str(item["package_path"]).encode("utf-8") + b"\0" + bytes.fromhex(str(item["sha256"])))
    value = {
        "schema": "pf07.distribution-content-bindings.v1",
        "fixture_version": "offset-objects-1.0.0",
        "plugin_version": "0.2.0",
        "plugin_schema_version": "1.1.0",
        "payload_schema_version": "1",
        "file_count": len(rows),
        "content_set_sha256": digest.hexdigest(),
        "files": rows,
    }
    OUTPUT.write_text(json.dumps(value, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    print(f"PF07_BOOTSTRAP_BINDING_FILES={len(rows)}")
    print(f"PF07_BOOTSTRAP_CONTENT_SET_SHA256={value['content_set_sha256']}")


if __name__ == "__main__":
    main()
