#!/usr/bin/env python3
from __future__ import annotations

import hashlib
import json
import os
from pathlib import Path
import re
import shutil
import stat
import subprocess
import sys
from urllib.request import Request, urlopen

sys.dont_write_bytecode = True
os.environ["PYTHONDONTWRITEBYTECODE"] = "1"

from evidence_contract import EvidenceContractError, validate_public_record_shape
from refinement_evidence_paths import (
    LEGACY_PUBLIC_MANIFEST_SHA256,
    PUBLIC_RUN_ALIAS,
    SUCCESSOR_PUBLIC_PREFIX,
    successor_public_root,
)


def fail(message: str) -> None:
    raise SystemExit(f"FAIL: {message}")


if len(sys.argv) != 2 or sys.argv[1] not in ("--pre-public", "--repository-public", "--post-public"):
    fail("usage: scripts/validate-public <--pre-public|--repository-public|--post-public>")

mode = sys.argv[1]
root = Path(__file__).resolve().parent.parent
allowlist = json.loads((root / "release/public-allowlist.json").read_text(encoding="utf-8"))["paths"]
manifest_path = root / "release/public-build-manifest.json"
expected_candidate_files: list[str] | None = None


def candidate_files() -> list[str]:
    entries: list[str] = []
    for path in root.rglob("*"):
        relative = path.relative_to(root)
        if relative.parts[0] == ".git" or "node_modules" in relative.parts:
            continue
        if path.is_file() or path.is_symlink():
            entries.append(relative.as_posix())
    return sorted(entries)


if manifest_path.exists():
    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    manifest_paths = [entry["path"] for entry in manifest.get("files", [])]
    if manifest_paths != allowlist:
        fail("generated manifest order or inventory differs from allowlist")
    expected_candidate_files = sorted([*allowlist, "release/public-build-manifest.json"])
    if candidate_files() != expected_candidate_files:
        fail("public candidate contains files outside the generated exact inventory")
    for entry in manifest.get("files", []):
        path = root / entry["path"]
        mode_value = "0755" if path.stat().st_mode & stat.S_IXUSR else "0644"
        if hashlib.sha256(path.read_bytes()).hexdigest() != entry["sha256"] or mode_value != entry["mode"]:
            fail(f"generated manifest bytes or mode differ: {entry['path']}")

for forbidden in (
    "evidence/raw",
    "evidence/refinement/raw-private",
    "backup",
    "backups",
    "credentials",
    "runtime",
    ".env",
    "reports/FINAL-REPORT.md",
    "reports/PF07-REFINEMENT-FINAL-REPORT.md",
):
    if any(path == forbidden or path.startswith(forbidden + "/") for path in allowlist):
        fail(f"protected path is allowlisted: {forbidden}")

secret_patterns = [
    re.compile(r"-----BEGIN (?:OPENSSH|RSA|EC|DSA) PRIVATE KEY-----"),
    re.compile(r"(?i)authorization\s*:\s*bearer\s+[a-z0-9._-]{12,}"),
    re.compile(r"(?m)^\s*[A-Z0-9_]*(?:API_KEY|TOKEN|PASSWORD|SECRET)[A-Z0-9_]*\s*=\s*(?![<$])[^\s#]{8,}\s*$"),
    re.compile(r"(?m)^\s*[A-Z0-9_]*(?:API_KEY|TOKEN|PASSWORD|SECRET)[A-Z0-9_]*\s*:\s*(?![$<{])[^\s#]{8,}\s*$"),
    re.compile(r"(?i)(?:api[_-]?key|token|password|secret)\s*=\s*['\"](?![$<])(?![^'\"]*(?:synthetic|example|test))[^'\"]{8,}['\"]"),
    re.compile("/" + "home/" + r"[^/<\s]+/"),
    re.compile(
        r"(?i)hooks\.slack\.com/services|ngrok-free\.(?:app|dev)|v1:pf" +
        r"07-(?!00000000-0000-4000-8000-000000000000)[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}:[0-9]{1,19}:(?:ORDER_CREATED|PAYMENT_CONFIRMED|ORDER_CANCELLED|ORDER_REFUNDED)"
    ),
]
binary_secret_patterns = [
    re.compile(b"-----BEGIN (?:OPENSSH|RSA|EC|DSA) PRIVATE KEY-----"),
    re.compile(b"(?i)authorization\\s*:\\s*bearer\\s+[a-z0-9._-]{12,}"),
    re.compile(
        b"(?i)hooks\\.slack\\.com/services|ngrok-free\\.(?:app|dev)|v1:pf" +
        b"07-(?!00000000-0000-4000-8000-000000000000)[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}:[0-9]{1,19}:(?:ORDER_CREATED|PAYMENT_CONFIRMED|ORDER_CANCELLED|ORDER_REFUNDED)"
    ),
    re.compile(b"/" + b"home/[^/<\\s]+/"),
]
public_container_paths = ("/home/node/.n8n",)
for relative in allowlist:
    path = root / relative
    if not path.is_file() or path.is_symlink():
        fail(f"allowlisted regular file is missing: {relative}")
    binary_scan = path.read_bytes().replace(b"/home/node/.n8n", b"<PUBLIC_CONTAINER_PATH>")
    for pattern in binary_secret_patterns:
        if pattern.search(binary_scan):
            fail(f"public-bound binary secret, protected identifier, or owner-path pattern in {relative}")
    try:
        text = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        continue
    scan_text = text
    for public_container_path in public_container_paths:
        scan_text = scan_text.replace(public_container_path, "<PUBLIC_CONTAINER_PATH>")
    for pattern in secret_patterns:
        if pattern.search(scan_text):
            fail(f"public-bound secret, protected identifier, or owner-path pattern in {relative}")

legacy_public_root = root / "evidence/public"
legacy_manifest_path = legacy_public_root / "evidence-manifest.sha256"
if not legacy_manifest_path.is_file() or hashlib.sha256(legacy_manifest_path.read_bytes()).hexdigest() != LEGACY_PUBLIC_MANIFEST_SHA256:
    fail("historical v1.0.2 public evidence manifest changed")
legacy_manifest_entries: dict[str, str] = {}
for line in legacy_manifest_path.read_text(encoding="utf-8").splitlines():
    match = re.fullmatch(r"([0-9a-f]{64})  (evidence/public/[a-z0-9-]+\.(?:json|txt))", line)
    if not match or match.group(2) in legacy_manifest_entries:
        fail("historical public evidence manifest line is invalid or duplicated")
    legacy_manifest_entries[match.group(2)] = match.group(1)
expected_legacy_manifest = {
    path.relative_to(root).as_posix(): hashlib.sha256(path.read_bytes()).hexdigest()
    for path in legacy_public_root.glob("*")
    if path.is_file() and path.name != "evidence-manifest.sha256"
}
if legacy_manifest_entries != expected_legacy_manifest:
    fail("historical v1.0.2 public evidence bytes changed")

public_root = successor_public_root(root)
manifest_entries: dict[str, str] = {}
for line in (public_root / "evidence-manifest.sha256").read_text(encoding="utf-8").splitlines():
    match = re.fullmatch(rf"([0-9a-f]{{64}})  ({re.escape(SUCCESSOR_PUBLIC_PREFIX)}/[a-z0-9-]+\.(?:json|txt))", line)
    if not match or match.group(2) in manifest_entries:
        fail("public evidence manifest line is invalid or duplicated")
    manifest_entries[match.group(2)] = match.group(1)
expected_manifest = {
    path.relative_to(root).as_posix(): hashlib.sha256(path.read_bytes()).hexdigest()
    for path in public_root.glob("*")
    if path.is_file() and path.name != "evidence-manifest.sha256"
}
if manifest_entries != expected_manifest:
    fail("public evidence manifest inventory or hash mismatch")

fixture_document = json.loads((root / "fixtures/acceptance-fixtures.json").read_text(encoding="utf-8"))
fixture_items = fixture_document.get("fixtures")
if fixture_document.get("schema_version") != 1 or not isinstance(fixture_items, list) or len(fixture_items) != 15:
    fail("public fixture inventory is invalid")
expected_records: dict[str, str] = {}
for fixture in fixture_items:
    if not isinstance(fixture, dict) or not isinstance(fixture.get("record"), str) or not isinstance(fixture.get("acceptance_id"), str):
        fail("public fixture record identity is invalid")
    if fixture["record"] in expected_records:
        fail("public fixture record identity is duplicated")
    expected_records[fixture["record"]] = fixture["acceptance_id"]
expected_records["vsl-pass.json"] = "VSL-PASS"
if set(manifest_entries) != {f"{SUCCESSOR_PUBLIC_PREFIX}/{name}" for name in expected_records} | {f"{SUCCESSOR_PUBLIC_PREFIX}/acceptance-matrix.json"}:
    fail("successor public evidence inventory differs from fifteen gate records, VSL, and buyer-proof matrix")

transform_sha = hashlib.sha256((root / "scripts/generate-public-evidence").read_bytes()).hexdigest()
public_records: dict[str, dict] = {}
source_tree_hashes: set[str] = set()
for relative, digest in manifest_entries.items():
    record = json.loads((root / relative).read_text(encoding="utf-8"))
    if relative.endswith("acceptance-matrix.json"):
        continue
    name = Path(relative).name
    try:
        validate_public_record_shape(record, transform_sha)
    except EvidenceContractError as error:
        fail(f"public evidence common schema or transform failed: {relative}: {error}")
    if record.get("acceptance_id") != expected_records.get(name):
        fail(f"public evidence identity differs from the fixture contract: {relative}")
    public_records[name] = record
    source_tree_hashes.add(record["source_tree_sha256"])
if set(public_records) != set(expected_records) or len(source_tree_hashes) != 1:
    fail("public evidence records do not form one complete source-bound set")

matrix = json.loads((public_root / "acceptance-matrix.json").read_text(encoding="utf-8"))
entries = matrix.get("entries")
expected_gates = [f"GATE-{index:02d}" for index in range(1, 11)]
if (
    set(matrix) != {
        "schema_version", "acceptance_id", "run_id", "started_at", "finished_at",
        "source_tree_sha256", "command_or_probe", "exit_code", "observations",
        "artifact_hashes", "redaction_state", "matrix_scope", "entries",
    }
    or matrix.get("schema_version") != "1"
    or matrix.get("acceptance_id") != "ACCEPTANCE-MATRIX"
    or matrix.get("run_id") != PUBLIC_RUN_ALIAS
    or matrix.get("source_tree_sha256") != next(iter(source_tree_hashes))
    or matrix.get("command_or_probe") != "pre-public buyer-proof index over generated public records"
    or matrix.get("exit_code") != 0
    or matrix.get("observations") != {"result": "PASS", "gate_count": 10, "final_pass_claimed": False}
    or matrix.get("artifact_hashes") != {}
    or matrix.get("redaction_state") != "PUBLIC_ORIGINAL_SAFE"
    or matrix.get("matrix_scope") != "PRE_PUBLIC_BUYER_PROOF"
    or not isinstance(entries, list)
    or [entry.get("acceptance_id") for entry in entries] != expected_gates
):
    fail("public buyer-proof matrix scope or exact ten-gate inventory failed")
if any(entry.get("result") != "PASS" or manifest_entries.get(entry.get("record_path")) != entry.get("record_sha256") for entry in entries):
    fail("public buyer-proof matrix record link failed")
if any(str(entry.get("acceptance_id", "")).startswith(("REL-", "ACC-")) for entry in entries) or matrix.get("observations", {}).get("final_pass_claimed") is not False:
    fail("pre-public matrix contains a release/final claim")

fixture_result = subprocess.run(
    [str(root / "fixtures/run"), "--public"],
    cwd=root,
    text=True,
    stdout=subprocess.PIPE,
    stderr=subprocess.STDOUT,
    check=False,
)
if fixture_result.returncode != 0:
    fail(f"public executable fixture bundle failed: {fixture_result.stdout.strip()}")
fixture_summary = json.loads(fixture_result.stdout)
if fixture_summary.get("status") != "PASS" or fixture_summary.get("fixture_count") != 15:
    fail("public fixture bundle did not establish all fifteen scenarios")

case = (root / "case-study/README.md").read_text(encoding="utf-8")
claims = (root / "docs/CLAIMS-BOUNDARY.md").read_text(encoding="utf-8")
architecture = (root / "case-study/architecture.svg").read_text(encoding="utf-8")
for phrase in [
    "구매자가 겪는 문제", "Proof scorecard", "What this proves", "What this does not prove",
    "ON_DEMAND_ONLY", "Buyer fit / non-fit", "60–90", "recovery-clip.mp4",
    "Formal exactly-once", "captured, still-valid signed request", "source-available dependency",
]:
    if phrase.lower() not in (case + claims + architecture).lower():
        fail(f"public case/claims requirement is missing: {phrase}")

for markdown in [root / "README.md", root / "case-study/README.md", *sorted((root / "docs").glob("*.md"))]:
    text = markdown.read_text(encoding="utf-8")
    for target in re.findall(r"\[[^\]]+\]\(([^)]+)\)", text):
        if re.match(r"(?:https?://|#|mailto:)", target):
            continue
        resolved = (markdown.parent / target.split("#", 1)[0]).resolve()
        try:
            resolved.relative_to(root)
        except ValueError:
            fail(f"internal link escapes public tree: {markdown.name}:{target}")
        if not resolved.exists():
            fail(f"broken internal link: {markdown.name}:{target}")

if shutil.which("php"):
    subprocess.run(["php", "plugin/oddroom-orderops/tests/run.php"], cwd=root, check=True)
elif shutil.which("docker"):
    subprocess.run([
        "docker", "run", "--rm", "--volume", f"{root}:/workspace:ro",
        "--workdir", "/workspace", "php:8.3-cli",
        "php", "plugin/oddroom-orderops/tests/run.php",
    ], check=True)
else:
    fail("PHP 8.1+ or Docker is required for plugin tests")

if mode in ("--repository-public", "--post-public"):
    def fetch(url: str) -> bytes:
        request = Request(url, headers={"User-Agent": "PF07-public-validator/1"})
        with urlopen(request, timeout=20) as response:
            if response.status != 200:
                fail(f"public URL returned {response.status}: {url}")
            return response.read()

    repository_page = fetch("https://github.com/Cetacean916/oddroom-woo-orderops")
    if b"OddRoom Woo OrderOps" not in repository_page:
        fail("unauthenticated repository page lacks the project identity")
    remote_matrix = fetch(f"https://raw.githubusercontent.com/Cetacean916/oddroom-woo-orderops/main/{SUCCESSOR_PUBLIC_PREFIX}/acceptance-matrix.json")
    if hashlib.sha256(remote_matrix).hexdigest() != hashlib.sha256((public_root / "acceptance-matrix.json").read_bytes()).hexdigest():
        fail("public repository evidence differs from the validated clone")

if mode == "--post-public":
    showcase_js = fetch("https://cetacean916.github.io/portfolio-showcase/assets/js/projects.js")
    if b'id: "pf07"' not in showcase_js or b"GATE-10" not in showcase_js:
        fail("deployed showcase data lacks the PF07 case or scorecard")
    for url in [
        "https://cetacean916.github.io/portfolio-showcase/case.html?id=pf07",
        "https://cetacean916.github.io/portfolio-showcase/assets/media/pf07/main-image.png",
        "https://cetacean916.github.io/portfolio-showcase/assets/media/pf07/demo-video.mp4",
        "https://cetacean916.github.io/portfolio-showcase/assets/media/pf07/recovery-clip.mp4",
    ]:
        if not fetch(url):
            fail(f"deployed public case asset is empty: {url}")
    subprocess.run(["node", "tests/public_case_quality.mjs"], cwd=root, check=True)

suffix = ", public repository" if mode == "--repository-public" else ", public repository and deployed case" if mode == "--post-public" else ""
if expected_candidate_files is not None and candidate_files() != expected_candidate_files:
    fail("public validation mutated the generated exact inventory")
print(f"PASS: {mode[2:]} public tree, evidence, fixtures, claims, links, unit checks{suffix}")
