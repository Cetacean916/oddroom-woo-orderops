#!/usr/bin/env python3
from __future__ import annotations

import json
from pathlib import Path
import sys


ROOT = Path(__file__).resolve().parent.parent
TARGET = ROOT / "workflow/oddroom-orderops-vsl.json"
PACKAGE_TARGET = ROOT / "packaging/common/workflows/connected-mode.json"
CREDENTIAL = {"httpBearerAuth": {"id": "PF07HubSpotRuntime1", "name": "PF07 HubSpot Runtime"}}
SLACK_CREDENTIAL = {"httpHeaderAuth": {"id": "PF07SlackRuntime1", "name": "PF07 Slack Runtime"}}


def code(node_id: str, name: str, source: str, x: int, y: int = -80) -> dict:
    return {
        "parameters": {"mode": "runOnceForAllItems", "language": "javaScript", "jsCode": source.strip()},
        "id": node_id,
        "name": name,
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [x, y],
    }


def branch(node_id: str, name: str, field: str, x: int, y: int = -80) -> dict:
    return {
        "parameters": {
            "conditions": {
                "boolean": [{"value1": f"={{{{ $json.{field} }}}}", "operation": "equal", "value2": True}]
            }
        },
        "id": node_id,
        "name": name,
        "type": "n8n-nodes-base.if",
        "typeVersion": 1,
        "position": [x, y],
    }


def request(
    node_id: str,
    name: str,
    method: str,
    url: str,
    x: int,
    body: str | None = None,
    y: int = -80,
    auth_type: str = "httpBearerAuth",
    credential: dict | None = None,
    continue_on_error: bool = False,
) -> dict:
    parameters: dict[str, object] = {
        "method": method,
        "url": url,
        "authentication": "genericCredentialType",
        "genericAuthType": auth_type,
        "options": {
            "response": {
                "response": {"fullResponse": True, "neverError": True, "responseFormat": "json"}
            },
            "timeout": 120000,
        },
    }
    if body is not None:
        parameters.update({"sendBody": True, "contentType": "json", "specifyBody": "json", "jsonBody": body})
    node = {
        "parameters": parameters,
        "id": node_id,
        "name": name,
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.4,
        "position": [x, y],
        "credentials": credential or CREDENTIAL,
    }
    if continue_on_error:
        node["onError"] = "continueRegularOutput"
    return node


VERIFY = r"""
const crypto = require('crypto');
const BigNumber = require('bignumber.js');
const JSONbig = require('json-bigint')({ protoAction: 'error', constructorAction: 'error' });
const item = $input.first();
const sourceHeaders = item.json.headers ?? {};
const headers = {};
for (const [key, value] of Object.entries(sourceHeaders)) headers[String(key).toLowerCase()] = Array.isArray(value) ? String(value[0] ?? '') : String(value ?? '');
const rawBase64 = item.binary?.data?.data;
const raw = typeof rawBase64 === 'string' ? Buffer.from(rawBase64, 'base64') : Buffer.alloc(0);
const reject = (errorCode, statusCode) => [{ json: { authorized: false, status_code: statusCode, error: { error_code: errorCode } } }];
if (raw.length > 262144) return reject('PAYLOAD_TOO_LARGE', 413);
const eventKey = headers['x-oddroom-event-key'] ?? '';
const timestampText = headers['x-oddroom-timestamp'] ?? '';
const phase = headers['x-oddroom-resume-phase'] ?? '';
const supplied = headers['x-oddroom-signature'] ?? '';
const eventTypes = {
  ORDER_CREATED: { rank: 10, source: 'date_created' },
  PAYMENT_CONFIRMED: { rank: 20, source: 'date_paid' },
  ORDER_CANCELLED: { rank: 30, source: '_oddroom_orderops_cancelled_at_utc' },
  ORDER_REFUNDED: { rank: 40, source: 'full_refund_completion' },
};
if (!/^v1:pf07-[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}:(?:0|[1-9][0-9]{0,18}):(ORDER_CREATED|PAYMENT_CONFIRMED|ORDER_CANCELLED|ORDER_REFUNDED)$/.test(eventKey)) return reject('SIGNATURE_INVALID', 401);
if (!/^[1-9][0-9]{0,10}$/.test(timestampText) || !['created','deal_resolved','contact_upserted','deal_upserted','associated','slack_pending'].includes(phase)) return reject('SIGNATURE_INVALID', 401);
if (!/^v1=[0-9a-f]{64}$/.test(supplied)) return reject('SIGNATURE_INVALID', 401);
const secret = String($env.ODDROOM_WEBHOOK_HMAC_KEY ?? '');
if (secret.length < 16) throw new Error('HMAC credential alias is unavailable');
const base = Buffer.concat([Buffer.from(`${timestampText}.${eventKey}.${phase}.`, 'utf8'), raw]);
const expected = 'v1=' + crypto.createHmac('sha256', secret).update(base).digest('hex');
const providedBytes = Buffer.from(supplied, 'utf8');
const expectedBytes = Buffer.from(expected, 'utf8');
if (providedBytes.length !== expectedBytes.length || !crypto.timingSafeEqual(providedBytes, expectedBytes)) return reject('SIGNATURE_INVALID', 401);
const timestamp = Number(timestampText);
if (!Number.isSafeInteger(timestamp) || Math.abs(Math.floor(Date.now() / 1000) - timestamp) > 300) return reject('TIMESTAMP_EXPIRED', 401);
let payload;
const rawText = raw.toString('utf8');
if (!Buffer.from(rawText, 'utf8').equals(raw)) return reject('PAYLOAD_INVALID', 400);
try { payload = JSONbig.parse(rawText); } catch { return reject('PAYLOAD_INVALID', 400); }
const order = payload?.order;
const eventRule = eventTypes[payload?.event_type];
const selectedCurrency = 'KRW';
const selectedCurrencyPrecision = 2;
const money = new RegExp(`^(?:0|[1-9][0-9]{0,17})\\.[0-9]{${selectedCurrencyPrecision}}$`);
const bounded = (value, min, max) => {
  if (typeof value !== 'string') return false;
  const length = Array.from(value).length;
  return length >= min && length <= max;
};
const plainObject = (value) => value !== null && typeof value === 'object' && !Array.isArray(value) && !BigNumber.isBigNumber(value);
const exactKeys = (value, keys) => {
  if (!plainObject(value)) return false;
  const actual = Object.keys(value);
  return actual.length === keys.length && actual.every((key, index) => key === keys[index]);
};
const utcSecond = (value) => {
  if (typeof value !== 'string' || !/^[1-9][0-9]{3}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$/.test(value)) return false;
  const instant = Date.parse(value);
  return Number.isFinite(instant) && new Date(instant).toISOString() === `${value.slice(0, -1)}.000Z`;
};
const signed64Max = new BigNumber('9223372036854775807');
const signed64 = (value, allowZero) => {
  if (typeof value === 'number') return Number.isSafeInteger(value) && (allowZero ? value >= 0 : value > 0);
  return BigNumber.isBigNumber(value) && value.isInteger() && (allowZero ? value.gte(0) : value.gt(0)) && value.lte(signed64Max);
};
const validItem = (value) => exactKeys(value, ['item_id','product_id','variation_id','sku','name','quantity','line_total']) && signed64(value.item_id, true) && signed64(value.product_id, true) && signed64(value.variation_id, true) && bounded(value.sku, 0, 255) && bounded(value.name, 1, 255) && Number.isSafeInteger(value.quantity) && value.quantity >= 1 && value.quantity <= 1000000 && money.test(value.line_total ?? '');
const validCoupon = (value) => bounded(value, 1, 255);
const valid = exactKeys(payload, ['schema_version','event_key','shop_instance_id','run_id','event_type','occurred_at_utc','occurred_at_source','state_rank','order']) && payload.schema_version === '1' && payload.event_key === eventKey && bounded(payload.shop_instance_id, 1, 64) && /^pf07-[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/.test(payload.shop_instance_id) && typeof payload.run_id === 'string' && /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/.test(payload.run_id) && eventRule && payload.state_rank === eventRule.rank && utcSecond(payload.occurred_at_utc) && payload.occurred_at_source === eventRule.source && exactKeys(order, ['id','number','currency','total','customer','items','coupon_codes']) && signed64(order.id, true) && bounded(order.number, 1, 255) && order.currency === selectedCurrency && money.test(order.total ?? '') && exactKeys(order.customer, ['email','first_name','last_name']) && bounded(order.customer.email, 1, 254) && order.customer.email === order.customer.email.toLowerCase() && /^[^@\s]+@example\.com$/.test(order.customer.email) && bounded(order.customer.first_name, 1, 255) && bounded(order.customer.last_name, 1, 255) && Array.isArray(order.items) && order.items.length >= 1 && order.items.length <= 100 && order.items.every(validItem) && Array.isArray(order.coupon_codes) && order.coupon_codes.length <= 50 && order.coupon_codes.every(validCoupon);
if (!valid) return reject(payload?.schema_version === '1' ? 'PAYLOAD_INVALID' : 'SCHEMA_UNSUPPORTED', 400);
const expectedKey = `v1:${payload.shop_instance_id}:${order.id}:${payload.event_type}`;
if (eventKey !== expectedKey) return reject('PAYLOAD_INVALID', 400);
const orderKey = `${payload.shop_instance_id}:${order.id}`;
const normalize = (value) => {
  if (BigNumber.isBigNumber(value)) return value.toFixed(0);
  if (Array.isArray(value)) return value.map(normalize);
  if (value && typeof value === 'object') return Object.fromEntries(Object.entries(value).map(([key, child]) => [key, normalize(child)]));
  return value;
};
return [{ json: { authorized: true, event_key: eventKey, resume_phase: phase, payload: normalize(payload), order_key: orderKey, deal_read_body: { idProperty: 'oddroom_wc_order_key', properties: ['oddroom_wc_order_key','oddroom_order_state','oddroom_order_state_rank','oddroom_last_event_at','oddroom_last_event_key','dealname','pipeline','dealstage'], inputs: [{ id: orderKey }] } } }];
"""


RESOLVE = r"""
const context = $('Verify HMAC Then Decode').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 200);
const body = response.body ?? response;
const initialSlack = context.payload.event_type === 'ORDER_CREATED' ? 'not_required' : 'pending';
const envelope = (result, phase, contactId, dealId, slackStatus, retryable, errorCode, errorMessage) => ({ schema_version: '1', event_key: context.event_key, result, processing_phase: phase, remote_contact_id: contactId ?? null, remote_deal_id: dealId ?? null, slack_status: slackStatus, slack_message_ts: null, retryable, retry_after_seconds: null, error_code: errorCode ?? null, error_message: errorMessage ?? null });
const stop = (responseCode, value) => [{ json: { continue_work: false, response_code: responseCode, envelope: value } }];
if (statusCode === 401 || statusCode === 403) return stop(422, envelope('terminal_error', context.resume_phase, null, null, initialSlack, false, 'HUBSPOT_AUTH', 'HubSpot authorization was rejected.'));
if (statusCode < 200 || statusCode >= 300) return stop(503, envelope('retryable_error', context.resume_phase, null, null, initialSlack, true, 'HUBSPOT_RETRYABLE', 'HubSpot Deal resolution was unavailable.'));
if (body?.status !== 'COMPLETE') return stop(503, envelope('retryable_error', context.resume_phase, null, null, initialSlack, true, 'HUBSPOT_RETRYABLE', 'HubSpot Deal resolution did not complete.'));
const results = Array.isArray(body?.results) ? body.results : [];
if (results.length > 1) return stop(422, envelope('terminal_error', context.resume_phase, null, null, initialSlack, false, 'HUBSPOT_SCHEMA', 'Deal identity resolution was ambiguous.'));
const existing = results[0] ?? null;
const existingId = existing ? String(existing.id ?? '') : null;
if (existing && existingId === '') return stop(422, envelope('terminal_error', context.resume_phase, null, null, initialSlack, false, 'HUBSPOT_SCHEMA', 'Deal identity was malformed.'));
const existingRank = existing ? Number(existing.properties?.oddroom_order_state_rank) : -1;
const existingKey = existing?.properties?.oddroom_last_event_key ?? null;
const existingOrderKey = existing?.properties?.oddroom_wc_order_key ?? null;
const existingState = existing?.properties?.oddroom_order_state ?? null;
const existingAt = existing?.properties?.oddroom_last_event_at ?? null;
const remoteRules = { ORDER_CREATED: 10, PAYMENT_CONFIRMED: 20, ORDER_CANCELLED: 30, ORDER_REFUNDED: 40 };
const validRemoteAt = typeof existingAt === 'string' && /^[1-9][0-9]{3}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$/.test(existingAt) && Number.isFinite(Date.parse(existingAt)) && new Date(Date.parse(existingAt)).toISOString() === `${existingAt.slice(0, -1)}.000Z`;
const expectedExistingKey = typeof existingState === 'string' ? `v1:${context.payload.shop_instance_id}:${context.payload.order.id}:${existingState}` : null;
if (existing && (!Number.isInteger(existingRank) || remoteRules[existingState] !== existingRank || existingKey !== expectedExistingKey || existingOrderKey !== context.order_key || !validRemoteAt)) return stop(422, envelope('terminal_error', context.resume_phase, null, existingId, initialSlack, false, 'HUBSPOT_SCHEMA', 'Deal authoritative state was malformed.'));
if (existing && existingRank === context.payload.state_rank && existingKey !== context.event_key) return stop(422, envelope('terminal_error', context.resume_phase, null, existingId, initialSlack, false, 'HUBSPOT_SCHEMA', 'Equal-rank remote state has a different event key.'));
if (existing && existingRank > context.payload.state_rank) return stop(200, envelope('stale_ignored', 'completed', null, existingId, 'not_required', false, null, null));
const phaseOrder = ['created','deal_resolved','contact_upserted','deal_upserted','associated','slack_pending'];
const phaseIndex = phaseOrder.indexOf(context.resume_phase);
const dealUpsertedIndex = phaseOrder.indexOf('deal_upserted');
let mode;
if (existing && existingRank === context.payload.state_rank) {
  if (context.resume_phase === 'created') {
    if (context.payload.event_type !== 'ORDER_CREATED') return stop(409, envelope('operator_review', 'created', null, existingId, initialSlack, false, 'RESUME_PHASE_CONFLICT', 'A Slack-producing created replay is ambiguous.'));
    mode = 'duplicate';
  } else {
    mode = 'resume';
  }
} else {
  if (phaseIndex >= dealUpsertedIndex) return stop(409, envelope('operator_review', context.resume_phase, null, existingId, initialSlack, false, 'RESUME_PHASE_CONFLICT', 'Remote Deal state does not establish the persisted resume phase.'));
  mode = context.resume_phase === 'created' ? 'advance' : 'resume';
}
const order = context.payload.order;
const contactBody = { inputs: [{ id: order.customer.email, idProperty: 'email', properties: { email: order.customer.email, firstname: order.customer.first_name, lastname: order.customer.last_name } }] };
const contactReadBody = { idProperty: 'email', properties: ['email','firstname','lastname'], inputs: [{ id: order.customer.email }] };
const dealBody = { inputs: [{ id: context.order_key, idProperty: 'oddroom_wc_order_key', properties: { dealname: `OFFSET order ${order.number}`, pipeline: String($env.HUBSPOT_PIPELINE_ID), dealstage: String($env.HUBSPOT_INITIAL_STAGE_ID), oddroom_wc_order_key: context.order_key, oddroom_order_state: context.payload.event_type, oddroom_order_state_rank: String(context.payload.state_rank), oddroom_last_event_at: context.payload.occurred_at_utc, oddroom_last_event_key: context.event_key } }] };
const readOnlyMode = mode === 'duplicate';
const sameEventState = Boolean(existing && existingRank === context.payload.state_rank && existingKey === context.event_key);
const contactMutationRequired = !readOnlyMode && phaseIndex <= phaseOrder.indexOf('deal_resolved');
const dealMutationRequired = !readOnlyMode && phaseIndex <= phaseOrder.indexOf('contact_upserted') && !sameEventState;
const associationMutationRequired = !readOnlyMode && phaseIndex <= phaseOrder.indexOf('deal_upserted');
return [{ json: { continue_work: true, response_code: null, envelope: null, mode, existing_deal_id: existingId, contact_mutation_required: contactMutationRequired, deal_mutation_required: dealMutationRequired, association_mutation_required: associationMutationRequired, contact_upsert_body: contactBody, contact_read_body: contactReadBody, deal_upsert_body: dealBody, deal_read_body: context.deal_read_body, initial_slack_status: initialSlack, trace: phaseOrder.slice(0, phaseIndex + 1) } }];
"""


VALIDATE_CONTACT_UPSERT = r"""
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Resolve Monotonic Deal State').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 200);
const body = response.body ?? response;
const failure = (code, message, terminal = false) => [{ json: { continue_contact_read: false, response_code: terminal ? 422 : 503, envelope: { schema_version: '1', event_key: context.event_key, result: terminal ? 'terminal_error' : 'retryable_error', processing_phase: 'deal_resolved', remote_contact_id: null, remote_deal_id: prepared.existing_deal_id ?? null, slack_status: prepared.initial_slack_status, slack_message_ts: null, retryable: !terminal, retry_after_seconds: null, error_code: code, error_message: message } } }];
if (statusCode === 401 || statusCode === 403) return failure('HUBSPOT_AUTH', 'HubSpot Contact authorization was rejected.', true);
const results = Array.isArray(body?.results) ? body.results : [];
if (statusCode < 200 || statusCode >= 300) return failure('HUBSPOT_RETRYABLE', 'HubSpot Contact upsert was unavailable.');
if (body?.status === 'PENDING' || body?.status === 'PROCESSING') return [{ json: { ...prepared, continue_contact_read: true, upsert_contact_id: null } }];
if (body?.status !== 'COMPLETE') return failure('HUBSPOT_RETRYABLE', 'HubSpot Contact upsert did not complete.');
if (results.length !== 1 || String(results[0]?.id ?? '') === '') return failure('HUBSPOT_SCHEMA', 'HubSpot Contact upsert returned an invalid identity.', true);
return [{ json: { ...prepared, continue_contact_read: true, upsert_contact_id: String(results[0].id) } }];
"""


VALIDATE_CONTACT_READ = r"""
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Resolve Monotonic Deal State').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 200);
const body = response.body ?? response;
let mutationOutput = null;
try { mutationOutput = $('Validate Contact Upsert').first().json; } catch {}
const upsertContactId = typeof mutationOutput?.upsert_contact_id === 'string' ? mutationOutput.upsert_contact_id : null;
const failurePhase = prepared.contact_mutation_required ? 'deal_resolved' : context.resume_phase;
const failure = (responseCode, result, code, message, phase = failurePhase, contactId = null) => [{ json: { continue_deal_stage: false, response_code: responseCode, envelope: { schema_version: '1', event_key: context.event_key, result, processing_phase: phase, remote_contact_id: contactId, remote_deal_id: prepared.existing_deal_id ?? null, slack_status: prepared.initial_slack_status, slack_message_ts: null, retryable: result === 'retryable_error', retry_after_seconds: null, error_code: code, error_message: message } } }];
if (statusCode === 401 || statusCode === 403) return failure(422, 'terminal_error', 'HUBSPOT_AUTH', 'HubSpot Contact read authorization was rejected.');
if (statusCode < 200 || statusCode >= 300 || body?.status !== 'COMPLETE') return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot Contact resolution was unavailable.');
const results = Array.isArray(body?.results) ? body.results : [];
const result = results[0] ?? null;
const contactId = result ? String(result.id ?? '') : '';
const properties = result?.properties ?? {};
const identityExact = results.length === 1 && contactId !== '' && properties.email === context.payload.order.customer.email;
const ownedFieldsExact = properties.firstname === context.payload.order.customer.first_name && properties.lastname === context.payload.order.customer.last_name;
const upsertIdentityExact = upsertContactId === null || upsertContactId === contactId;
if (!identityExact || !ownedFieldsExact || !upsertIdentityExact) {
  if (!prepared.contact_mutation_required) return failure(409, 'operator_review', 'RESUME_PHASE_CONFLICT', 'Remote Contact does not establish the persisted resume phase.');
  return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot Contact read-back was not exact.');
}
return [{ json: { ...prepared, continue_deal_stage: true, contact_id: contactId } }];
"""


VALIDATE_DEAL_UPSERT = r"""
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Validate Contact Read').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 200);
const body = response.body ?? response;
const results = Array.isArray(body?.results) ? body.results : [];
const failure = (responseCode, result, code, message) => [{ json: { continue_deal_read: false, response_code: responseCode, envelope: { schema_version: '1', event_key: context.event_key, result, processing_phase: 'contact_upserted', remote_contact_id: prepared.contact_id, remote_deal_id: prepared.existing_deal_id ?? null, slack_status: prepared.initial_slack_status, slack_message_ts: null, retryable: result === 'retryable_error', retry_after_seconds: null, error_code: code, error_message: message } } }];
if (statusCode === 401 || statusCode === 403) return failure(422, 'terminal_error', 'HUBSPOT_AUTH', 'HubSpot Deal authorization was rejected.');
if (statusCode < 200 || statusCode >= 300) return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot Deal upsert was unavailable.');
if (body?.status === 'PENDING' || body?.status === 'PROCESSING') return [{ json: { ...prepared, continue_deal_read: true, upsert_deal_id: null } }];
if (body?.status !== 'COMPLETE') return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot Deal upsert did not complete.');
if (results.length !== 1 || String(results[0]?.id ?? '') === '') return failure(422, 'terminal_error', 'HUBSPOT_SCHEMA', 'HubSpot Deal upsert returned an invalid identity.');
const dealId = String(results[0].id);
if (prepared.existing_deal_id && prepared.existing_deal_id !== dealId) return failure(422, 'terminal_error', 'HUBSPOT_SCHEMA', 'HubSpot Deal upsert changed the unique identity.');
return [{ json: { ...prepared, continue_deal_read: true, upsert_deal_id: dealId } }];
"""


VALIDATE_DEAL_READ = r"""
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Validate Contact Read').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 200);
const body = response.body ?? response;
let mutationOutput = null;
try { mutationOutput = $('Validate Deal Upsert').first().json; } catch {}
const upsertDealId = typeof mutationOutput?.upsert_deal_id === 'string' ? mutationOutput.upsert_deal_id : null;
const checkpointDealId = prepared.existing_deal_id ?? null;
const progressPhase = prepared.deal_mutation_required ? 'contact_upserted' : context.resume_phase;
const failure = (responseCode, resultKind, code, message, phase = progressPhase, dealId = checkpointDealId) => [{ json: { continue_association_stage: false, response_code: responseCode, envelope: { schema_version: '1', event_key: context.event_key, result: resultKind, processing_phase: phase, remote_contact_id: prepared.contact_id, remote_deal_id: dealId, slack_status: prepared.initial_slack_status, slack_message_ts: null, retryable: resultKind === 'retryable_error', retry_after_seconds: null, error_code: code, error_message: message } } }];
if (statusCode === 401 || statusCode === 403) return failure(422, 'terminal_error', 'HUBSPOT_AUTH', 'HubSpot Deal read authorization was rejected.');
if (statusCode < 200 || statusCode >= 300 || body?.status !== 'COMPLETE') return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot Deal read-back was unavailable.');
const results = Array.isArray(body?.results) ? body.results : [];
const result = results[0] ?? null;
const properties = result?.properties ?? {};
const dealId = result ? String(result.id ?? '') : '';
if (results.length !== 1 || dealId === '') {
  if (!prepared.deal_mutation_required) return failure(409, 'operator_review', 'RESUME_PHASE_CONFLICT', 'Remote Deal does not establish the persisted resume phase.', context.resume_phase, checkpointDealId);
  return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot Deal read-back was not exact.');
}
if ((prepared.existing_deal_id && prepared.existing_deal_id !== dealId) || (upsertDealId && upsertDealId !== dealId)) return failure(422, 'terminal_error', 'HUBSPOT_SCHEMA', 'HubSpot Deal identity changed during one execution.', progressPhase, dealId);
const rank = Number(properties.oddroom_order_state_rank);
const presentationExact = properties.dealname === `OFFSET order ${context.payload.order.number}` && properties.pipeline === String($env.HUBSPOT_PIPELINE_ID) && properties.dealstage === String($env.HUBSPOT_INITIAL_STAGE_ID);
const currentExact = properties.oddroom_wc_order_key === context.order_key && properties.oddroom_order_state === context.payload.event_type && rank === context.payload.state_rank && properties.oddroom_last_event_at === context.payload.occurred_at_utc && properties.oddroom_last_event_key === context.event_key && presentationExact;
if (!currentExact) {
  if (!prepared.deal_mutation_required) return failure(409, 'operator_review', 'RESUME_PHASE_CONFLICT', 'Remote Deal facts conflict with the persisted resume phase.', context.resume_phase, dealId);
  return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot Deal read-back was not exact.', progressPhase, dealId);
}
return [{ json: { ...prepared, continue_association_stage: true, deal_id: dealId, association_put_url: `https://api.hubapi.com/crm/objects/2026-03/contact/${encodeURIComponent(prepared.contact_id)}/associations/default/deal/${encodeURIComponent(dealId)}`, association_read_url: `https://api.hubapi.com/crm/objects/2026-03/contact/${encodeURIComponent(prepared.contact_id)}/associations/deal` } }];
"""


VALIDATE_ASSOCIATION_PUT = r"""
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Validate Deal Readback').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 200);
if (statusCode < 200 || statusCode >= 300) return [{ json: { continue_association_read: false, response_code: statusCode === 401 || statusCode === 403 ? 422 : 503, envelope: { schema_version: '1', event_key: context.event_key, result: statusCode === 401 || statusCode === 403 ? 'terminal_error' : 'retryable_error', processing_phase: 'deal_upserted', remote_contact_id: prepared.contact_id, remote_deal_id: prepared.deal_id, slack_status: prepared.initial_slack_status, slack_message_ts: null, retryable: !(statusCode === 401 || statusCode === 403), retry_after_seconds: null, error_code: statusCode === 401 || statusCode === 403 ? 'HUBSPOT_AUTH' : 'HUBSPOT_RETRYABLE', error_message: 'HubSpot association request was rejected.' } } }];
return [{ json: { ...prepared, continue_association_read: true } }];
"""


VALIDATE_FINAL = r"""
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Validate Deal Readback').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 200);
const body = response.body ?? response;
const results = Array.isArray(body?.results) ? body.results : [];
const associationPending = body?.status === 'PENDING' || body?.status === 'PROCESSING';
const associated = statusCode >= 200 && statusCode < 300 && !associationPending && results.some((value) => String(value?.toObjectId ?? value?.id ?? '') === prepared.deal_id);
const failure = (responseCode, result, code, message, phase) => [{ json: { continue_slack: false, response_code: responseCode, envelope: { schema_version: '1', event_key: context.event_key, result, processing_phase: phase, remote_contact_id: prepared.contact_id, remote_deal_id: prepared.deal_id, slack_status: prepared.initial_slack_status, slack_message_ts: null, retryable: result === 'retryable_error', retry_after_seconds: null, error_code: code, error_message: message }, trace: prepared.trace } }];
if (statusCode === 401 || statusCode === 403) return failure(422, 'terminal_error', 'HUBSPOT_AUTH', 'HubSpot association read authorization was rejected.', 'deal_upserted');
if (statusCode < 200 || statusCode >= 300) return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot association read-back was unavailable.', prepared.association_mutation_required ? 'deal_upserted' : context.resume_phase);
if (!associated) {
  if (!prepared.association_mutation_required) return failure(409, 'operator_review', 'RESUME_PHASE_CONFLICT', 'Remote association does not establish the persisted resume phase.', context.resume_phase);
  return failure(503, 'retryable_error', 'HUBSPOT_RETRYABLE', 'HubSpot association read-back was not exact.', 'deal_upserted');
}
if (prepared.mode === 'duplicate') return [{ json: { continue_slack: false, response_code: 200, envelope: { schema_version: '1', event_key: context.event_key, result: 'duplicate_noop', processing_phase: 'completed', remote_contact_id: prepared.contact_id, remote_deal_id: prepared.deal_id, slack_status: 'not_required', slack_message_ts: null, retryable: false, retry_after_seconds: null, error_code: null, error_message: null }, trace: [...prepared.trace,'completed'] } }];
if (context.payload.event_type === 'ORDER_CREATED') return [{ json: { continue_slack: false, response_code: 200, envelope: { schema_version: '1', event_key: context.event_key, result: 'completed', processing_phase: 'completed', remote_contact_id: prepared.contact_id, remote_deal_id: prepared.deal_id, slack_status: 'not_required', slack_message_ts: null, retryable: false, retry_after_seconds: null, error_code: null, error_message: null }, trace: [...prepared.trace,'associated','completed'] } }];
const order = context.payload.order;
const dealRef = `deal-…${prepared.deal_id.slice(-6)}`;
const text = [`run_id=${context.payload.run_id}`,`event_key=${context.event_key}`,`event_type=${context.payload.event_type}`,`order=${order.number}`,`currency=${order.currency}`,`total=${order.total}`,`deal_ref=${dealRef}`].join(' | ');
return [{ json: { continue_slack: true, contact_id: prepared.contact_id, deal_id: prepared.deal_id, slack_body: { channel: String($env.SLACK_CHANNEL_ID), text }, trace: [...prepared.trace,'associated','slack_pending'] } }];
"""


PREPARE_FAULT_LOOKUP = r"""
const crypto = require('crypto');
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Prepare Slack Or Complete').first().json;
const timestamp = String(Math.floor(Date.now() / 1000));
const base = `fault-status.${timestamp}.${context.event_key}.${context.payload.run_id}`;
const signature = 'v1=' + crypto.createHmac('sha256', String($env.ODDROOM_WEBHOOK_HMAC_KEY ?? '')).update(base, 'utf8').digest('hex');
return [{ json: { fault_timestamp: timestamp, fault_signature: signature, fault_lookup_body: { event_key: context.event_key, run_id: context.payload.run_id }, contact_id: prepared.contact_id, deal_id: prepared.deal_id, slack_body: prepared.slack_body, trace: prepared.trace } }];
"""


SLACK_FAULT_GATE = r"""
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Prepare Fault Lookup').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 0);
const body = response.body ?? response;
if (statusCode !== 200 || body?.authorized !== true) return [{ json: { send_slack: false, response_code: 503, envelope: { schema_version: '1', event_key: context.event_key, result: 'retryable_error', processing_phase: 'slack_pending', remote_contact_id: prepared.contact_id, remote_deal_id: prepared.deal_id, slack_status: 'failed_before_post', slack_message_ts: null, retryable: true, retry_after_seconds: null, error_code: 'SLACK_RETRYABLE_BEFORE_POST', error_message: 'Staging pre-post authorization could not be established.' }, trace: prepared.trace } }];
if (body?.active === true) return [{ json: { send_slack: false, response_code: 503, envelope: { schema_version: '1', event_key: context.event_key, result: 'retryable_error', processing_phase: 'slack_pending', remote_contact_id: prepared.contact_id, remote_deal_id: prepared.deal_id, slack_status: 'failed_before_post', slack_message_ts: null, retryable: true, retry_after_seconds: 1, error_code: 'SLACK_RETRYABLE_BEFORE_POST', error_message: 'Deterministic staging fault immediately before Slack post.' }, trace: prepared.trace } }];
if (body?.active !== false) return [{ json: { send_slack: false, response_code: 503, envelope: { schema_version: '1', event_key: context.event_key, result: 'retryable_error', processing_phase: 'slack_pending', remote_contact_id: prepared.contact_id, remote_deal_id: prepared.deal_id, slack_status: 'failed_before_post', slack_message_ts: null, retryable: true, retry_after_seconds: null, error_code: 'SLACK_RETRYABLE_BEFORE_POST', error_message: 'Staging pre-post state was malformed.' }, trace: prepared.trace } }];
return [{ json: { send_slack: true, contact_id: prepared.contact_id, deal_id: prepared.deal_id, slack_body: prepared.slack_body, trace: prepared.trace } }];
"""


VALIDATE_SLACK = r"""
const context = $('Verify HMAC Then Decode').first().json;
const prepared = $('Slack Pre-Post Fault Gate').first().json;
const response = $input.first().json;
const statusCode = Number(response.statusCode ?? 0);
const body = response.body ?? response;
const headers = response.headers ?? {};
const envelope = (result, slackStatus, retryable, retryAfter, errorCode, errorMessage, ts = null) => ({ schema_version: '1', event_key: context.event_key, result, processing_phase: result === 'completed' ? 'completed' : 'slack_pending', remote_contact_id: prepared.contact_id, remote_deal_id: prepared.deal_id, slack_status: slackStatus, slack_message_ts: ts, retryable, retry_after_seconds: retryAfter, error_code: errorCode, error_message: errorMessage });
const responseChannel = String(body?.channel ?? '');
const ts = typeof body?.ts === 'string' && body.ts !== '' ? body.ts : null;
if (statusCode >= 200 && statusCode < 300 && body?.ok === true && responseChannel === String($env.SLACK_CHANNEL_ID) && ts) return [{ json: { response_code: 200, envelope: envelope('completed', 'posted', false, null, null, null, ts), trace: [...prepared.trace,'slack_posted','completed'] } }];
const slackError = typeof body?.error === 'string' ? body.error : '';
const retryHeader = headers['retry-after'] ?? headers['Retry-After'] ?? null;
const retryText = typeof retryHeader === 'string' || typeof retryHeader === 'number' ? String(retryHeader) : '';
const retryNumber = /^[0-9]+$/.test(retryText) ? Number(retryText) : NaN;
const retryAfter = Number.isSafeInteger(retryNumber) ? retryNumber : null;
if (statusCode === 429 || slackError === 'ratelimited' || slackError === 'internal_error' || slackError === 'fatal_error' || slackError === 'request_timeout') return [{ json: { response_code: 503, envelope: envelope('retryable_error', 'failed_before_post', true, retryAfter, 'SLACK_RETRYABLE_BEFORE_POST', 'Slack explicitly did not accept the message.'), trace: prepared.trace } }];
if (['invalid_auth','not_authed','missing_scope','account_inactive','token_revoked'].includes(slackError) || statusCode === 401 || statusCode === 403) return [{ json: { response_code: 422, envelope: envelope('terminal_error', 'failed_before_post', false, null, 'SLACK_AUTH', 'Slack authorization was rejected.'), trace: prepared.trace } }];
if (body?.ok === false && slackError !== '') return [{ json: { response_code: 422, envelope: envelope('terminal_error', 'failed_before_post', false, null, 'SLACK_TERMINAL', 'Slack rejected the message before acceptance.'), trace: prepared.trace } }];
return [{ json: { response_code: 409, envelope: envelope('operator_review', 'outcome_unknown', false, null, 'SLACK_OUTCOME_UNKNOWN', 'Slack acceptance could not be established from the response.'), trace: prepared.trace } }];
"""


