if sys.argv[1:] == ["--check"]:
    if not TARGET.exists() or TARGET.read_text(encoding="utf-8") != rendered:
        raise SystemExit("FAIL: generated workflow is stale")
    if not PACKAGE_TARGET.exists() or PACKAGE_TARGET.read_text(encoding="utf-8") != rendered:
        raise SystemExit("FAIL: packaged connected workflow is stale")
    print("PASS: generated and packaged workflows are current")
elif sys.argv[1:]:
    raise SystemExit("usage: scripts/build-workflow [--check]")
else:
    TARGET.write_text(rendered, encoding="utf-8")
    PACKAGE_TARGET.write_text(rendered, encoding="utf-8")
    print(f"PASS: generated {len(nodes)}-node workflow")
