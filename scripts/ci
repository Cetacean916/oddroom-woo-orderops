#!/usr/bin/env bash
set -euo pipefail

project_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
cd "$project_root"

python3 tests/test_public_builder.py
./scripts/build-workflow --check
python3 tests/test_vsl_contract.py
jq -e . workflow/oddroom-orderops-vsl.json >/dev/null
bash -n scripts/ci scripts/queue-runner scripts/runtime-materialize scripts/runtime-import-credentials scripts/runtime-wp-install

PF07_DB_PASSWORD=x \
PF07_DB_ROOT_PASSWORD=x \
N8N_RUNNERS_AUTH_TOKEN=x \
N8N_ENCRYPTION_KEY=x \
ODDROOM_WEBHOOK_HMAC_KEY=x \
HUBSPOT_RUNTIME_TOKEN=x \
ODDROOM_SHOP_INSTANCE_ID=pf07-synthetic \
ODDROOM_RUN_ID=00000000-0000-4000-8000-000000000000 \
HUBSPOT_PIPELINE_ID=default \
HUBSPOT_INITIAL_STAGE_ID=appointmentscheduled \
SLACK_CHANNEL_ID=C0000000000 \
docker compose -f infra/compose.yaml config --quiet

if command -v php >/dev/null 2>&1; then
  while IFS= read -r file; do
    php -l "$file" >/dev/null
  done < <(find plugin -type f -name '*.php' -print | sort)
  php plugin/oddroom-orderops/tests/run.php
elif command -v docker >/dev/null 2>&1; then
  docker run --rm --volume "$project_root:/workspace:ro" --workdir /workspace php:8.3-cli \
    sh -eu -c 'find plugin -type f -name "*.php" -print | sort | while IFS= read -r file; do php -l "$file" >/dev/null; done; php plugin/oddroom-orderops/tests/run.php'
else
  printf 'FAIL: PHP 8.1+ or Docker is required\n' >&2
  exit 1
fi

if test -f release/public-build-manifest.json; then
  ./scripts/validate-public --pre-public
fi

printf 'PASS: public-safe CI checks\n'
