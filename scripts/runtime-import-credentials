#!/usr/bin/env bash
set -euo pipefail

project_name=${1:-pf07-orderops-original}
project_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
runtime_dir="$project_root/runtime"
runtime_env="$runtime_dir/runtime.env"
compose_file="$project_root/infra/compose.yaml"
hubspot_secret="$runtime_dir/secrets/hubspot_runtime_token"
slack_secret="$runtime_dir/secrets/slack_bot_token"

for required in "$runtime_env" "$hubspot_secret" "$slack_secret"; do
  [[ -f "$required" && -s "$required" ]] || { echo "runtime credential material is unavailable" >&2; exit 66; }
done

umask 077
import_dir=$(mktemp -d "$runtime_dir/credential-import.XXXXXX")
container_hubspot=/tmp/pf07-hubspot-credential.json
container_slack=/tmp/pf07-slack-credential.json
cleanup() {
  docker compose --env-file "$runtime_env" -f "$compose_file" -p "$project_name" \
    exec -T -u 0 n8n rm -f "$container_hubspot" "$container_slack" >/dev/null 2>&1 || true
  rm -f "$import_dir/hubspot.json" "$import_dir/slack.json"
  rmdir "$import_dir" 2>/dev/null || true
}
trap cleanup EXIT

hubspot_token=$(tr -d '\r\n' < "$hubspot_secret")
slack_token=$(tr -d '\r\n' < "$slack_secret")
[[ -n "$hubspot_token" && -n "$slack_token" ]] || { echo "runtime credential value is empty" >&2; exit 65; }

jq -n --arg token "$hubspot_token" '[{
  id: "PF07HubSpotRuntime1",
  name: "PF07 HubSpot Runtime",
  type: "httpBearerAuth",
  data: {token: $token}
}]' > "$import_dir/hubspot.json"
jq -n --arg token "$slack_token" '[{
  id: "PF07SlackRuntime1",
  name: "PF07 Slack Runtime",
  type: "httpHeaderAuth",
  data: {name: "Authorization", value: ("Bearer " + $token)}
}]' > "$import_dir/slack.json"
chmod 600 "$import_dir/hubspot.json" "$import_dir/slack.json"

container_id=$(docker compose --env-file "$runtime_env" -f "$compose_file" -p "$project_name" ps -q n8n)
[[ -n "$container_id" ]] || { echo "n8n container is unavailable" >&2; exit 69; }
docker cp "$import_dir/hubspot.json" "$container_id:$container_hubspot" >/dev/null
docker cp "$import_dir/slack.json" "$container_id:$container_slack" >/dev/null
docker compose --env-file "$runtime_env" -f "$compose_file" -p "$project_name" \
  exec -T -u 0 n8n chown node:node "$container_hubspot" "$container_slack"
docker compose --env-file "$runtime_env" -f "$compose_file" -p "$project_name" \
  exec -T n8n n8n import:credentials --input="$container_hubspot"
docker compose --env-file "$runtime_env" -f "$compose_file" -p "$project_name" \
  exec -T n8n n8n import:credentials --input="$container_slack"

echo "PASS: imported encrypted HubSpot and Slack credential references"
